{
  "name": "vantage",
  "version": "1.2.0",
  "description": "Next Tab Page — A composable, high-performance NTP extension with live weather, RSS feeds, bookmarks, crypto prices, and more.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "audit": "node scripts/accessibility-audit.mjs",
    "build:unpacked": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-unpacked.ps1",
    "build:unpacked:firefox": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-unpacked.ps1 -Target firefox"
  },
  "devDependencies": {
    "@axe-core/puppeteer": "^4.11.4",
    "puppeteer": "^23.0.0"
  }
}
