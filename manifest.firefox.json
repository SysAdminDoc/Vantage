{
  "manifest_version": 3,
  "name": "Vantage",
  "version": "1.2.0",
  "description": "Customizable new tab dashboard — search engines, RSS, news, weather, and quick links. Privacy-first. No API keys required.",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "vantage@sysadmindoc",
      "strict_min_version": "109.0",
      "update_url": "https://raw.githubusercontent.com/SysAdminDoc/Vantage/main/firefox-updates.json"
    }
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Vantage settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "sidebar_action": {
    "default_title": "Vantage — Feeds",
    "default_panel": "sidepanel.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "open_at_install": false
  },
  "permissions": [
    "storage",
    "alarms",
    "bookmarks",
    "topSites",
    "contextualIdentities"
  ],
  "optional_permissions": [
    "history",
    "http://*/*",
    "https://*/*"
  ],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*",
    "https://air-quality-api.open-meteo.com/*",
    "https://marine-api.open-meteo.com/*",
    "https://flood-api.open-meteo.com/*",
    "https://ensemble-api.open-meteo.com/*",
    "https://api.allorigins.win/*",
    "https://corsproxy.io/*",
    "https://www.bing.com/*",
    "https://www.google.com/*",
    "https://api.github.com/*",
    "https://gist.githubusercontent.com/*",
    "https://api.coingecko.com/*",
    "https://api.nasa.gov/*",
    "https://picsum.photos/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
