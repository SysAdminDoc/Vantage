{
  "manifest_version": 3,
  "name": "Vantage",
  "version": "0.7.2",
  "description": "Customizable new tab dashboard — search engines, RSS, news, weather, and quick links. Privacy-first. No API keys required.",
  "browser_specific_settings": {
    "gecko": {
      "id": "vantage@sysadmindoc",
      "strict_min_version": "109.0"
    }
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Vantage settings",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": [
    "storage",
    "alarms",
    "bookmarks"
  ],
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*",
    "https://air-quality-api.open-meteo.com/*",
    "https://api.allorigins.win/*",
    "https://corsproxy.io/*",
    "*://*/*"
  ]
}
